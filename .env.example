# SnapLoad — Environment Variables
# Copy this to .env and fill in your values
# npm install dotenv  →  then add require('dotenv').config() at top of server.js

# Port to listen on (default: 3000)
PORT=3000

# Path to yt-dlp binary (if not on system PATH)
# YTDLP_PATH=/usr/local/bin/yt-dlp

# Temp directory for downloaded files (default: OS temp dir /snapload/)
# DOWNLOAD_TMP=/tmp/snapload

# CORS — restrict to your domain in production
# ALLOWED_ORIGIN=https://yourdomain.com
